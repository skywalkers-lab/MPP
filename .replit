modules = ["nodejs-20", "web", "bash", "python-3.11"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/dev-start.sh"
waitForPort = 5000

[[ports]]
localPort = 4000
externalPort = 3000

[[ports]]
localPort = 4001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "VIEWER_HTTP_PORT=5000 RELAY_WS_PORT=4000 npm run relay"]
build = ["bash", "-c", "cd client && npm install && npm run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
